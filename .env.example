# Hostname = somente: nome-do-servidor.database.windows.net (sem {}, sem região)
# No portal: SQL servers → seu servidor → copiar "Server name"
DB_SERVER=srv-calculadora-producao.database.windows.net
DB_NAME=CalculadoraDeArrobas
DB_USER=admin_calculadora
DB_PASSWORD=SUA_SENHA_AQUI
# Opcional (ms). Se ETIMEOUT: abra firewall no Azure para seu IP (não é só aumentar o timeout).
DB_CONNECT_TIMEOUT_MS=30000

# Front-end: URL da API em produção (deixe vazio em dev — o Vite encaminha /api para localhost:3001)
# VITE_API_BASE=https://sua-api.azurewebsites.net

# Firebase (Web SDK) — Console → Configurações do projeto → Seus apps
# Ative "E-mail/senha" em Authentication → Sign-in method
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=
# Opcionais (recomendado copiar do snippet do Console):
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=

# API Node: JSON da conta de serviço (Console → Config. do projeto → Contas de serviço → Gerar nova chave)
# Ou caminho para o arquivo .json (não commitar o arquivo real)
# FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-adminsdk.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}